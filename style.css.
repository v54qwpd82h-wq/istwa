:root {
  --bg: #080608;
  --cream: #f5efe6;
  --muted: #8a7a6e;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--cream);
  font-family: 'Lora', Georgia, serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HOME ── */
#home { display: block; }
#story-view { display: none; }
#episode-view { display: none; }

.home-hero {
  background: radial-gradient(ellipse 80% 60% at 50% 0%, #2a0a3a 0%, var(--bg) 70%);
  padding: 60px 24px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.home-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.home-badge {
  display: inline-block;
  border: 1px solid #c084fc55;
  color: #c084fc;
  font-family: 'Lora', serif;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 5px 16px;
  border-radius: 20px;
  margin-bottom: 20px;
}
.home-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(42px, 10vw, 72px);
  font-weight: 900;
  line-height: 1.05;
  background: linear-gradient(135deg, #ffffff 0%, #e8c4ff 60%, #c084fc 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12px;
}
.home-sub {
  color: var(--muted);
  font-style: italic;
  font-size: 15px;
}

.cards-wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 36px 16px 60px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.story-card {
  position: relative;
  border-radius: 22px;
  padding: 28px 24px;
  cursor: pointer;
  border: 1px solid transparent;
  overflow: hidden;
  transition: transform 0.25s ease, border-color 0.25s ease;
  text-align: left;
  width: 100%;
  background: none;
  color: var(--cream);
  font-family: 'Lora', serif;
}
.story-card:hover { transform: translateY(-3px); }
.card-emoji-bg {
  position: absolute;
  right: 20px; top: 50%;
  transform: translateY(-50%);
  font-size: 80px;
  opacity: 0.08;
  pointer-events: none;
  user-select: none;
}
.card-genre {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 1px;
  border-radius: 16px;
  padding: 3px 12px;
  border: 1px solid;
  margin-bottom: 10px;
}
.card-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(20px, 4vw, 26px);
  font-weight: 700;
  margin-bottom: 8px;
  color: #fff;
}
.card-desc {
  font-size: 14px;
  line-height: 1.65;
  color: #8a7a6a;
  margin-bottom: 18px;
}
.card-btn {
  display: inline-block;
  font-size: 13px;
  font-weight: 600;
  font-family: 'Lora', serif;
  border-radius: 10px;
  padding: 9px 20px;
  cursor: pointer;
  border: none;
  transition: opacity 0.2s;
}
.card-ep-count {
  font-size: 12px;
  color: #4a3a2a;
  margin-left: 12px;
  font-style: italic;
}

/* ── STORY (episodes list) ── */
.story-hero {
  padding: 40px 24px 32px;
  text-align: center;
  position: relative;
}
.back-btn {
  position: absolute;
  top: 16px; left: 16px;
  background: none;
  border: 1px solid;
  border-radius: 8px;
  padding: 7px 16px;
  font-size: 13px;
  font-family: 'Lora', serif;
  cursor: pointer;
  transition: opacity 0.2s;
}
.story-cover-emoji {
  font-size: 68px;
  margin-bottom: 14px;
}
.story-genre-tag {
  display: inline-block;
  font-size: 12px;
  letter-spacing: 1px;
  border-radius: 16px;
  padding: 4px 14px;
  border: 1px solid;
  margin-bottom: 12px;
}
.story-main-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 6vw, 44px);
  font-weight: 900;
  color: #fff;
  margin-bottom: 10px;
}
.story-main-desc {
  color: var(--muted);
  max-width: 480px;
  margin: 0 auto;
  font-size: 15px;
  font-style: italic;
  line-height: 1.7;
}

.ep-list-wrap {
  max-width: 640px;
  margin: 0 auto;
  padding: 24px 16px 60px;
}
.ep-list-label {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.ep-card {
  width: 100%;
  text-align: left;
  border-radius: 14px;
  padding: 20px;
  margin-bottom: 12px;
  cursor: pointer;
  border: 1px solid;
  background: none;
  color: var(--cream);
  font-family: 'Lora', serif;
  transition: background 0.2s;
}
.ep-num {
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 5px;
}
.ep-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 700;
  color: #fff;
}
.ep-cta {
  font-size: 12px;
  color: #5a4a3a;
  margin-top: 5px;
  font-style: italic;
}

/* ── EPISODE READER ── */
.ep-topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 20px;
  border-bottom: 1px solid #ffffff0a;
  position: sticky;
  top: 0;
  z-index: 10;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.ep-topbar-info {
  flex: 1;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.ep-content-wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 44px 24px 60px;
}
.ep-label {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.ep-heading {
  font-family: 'Playfair Display', serif;
  font-size: clamp(26px, 5.5vw, 38px);
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 36px;
}
.ep-text-box {
  border-radius: 18px;
  padding: 32px;
  border: 1px solid;
}
.ep-para {
  margin-bottom: 22px;
  line-height: 1.95;
  font-size: clamp(15px, 2.5vw, 17px);
}
.ep-para:last-child { margin-bottom: 0; }
.ep-para em {
  font-style: italic;
}

.ep-nav {
  display: flex;
  gap: 12px;
  margin-top: 36px;
}
.ep-nav-btn {
  flex: 1;
  border-radius: 12px;
  padding: 15px;
  font-size: 14px;
  font-family: 'Lora', serif;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid;
  transition: opacity 0.2s;
}
.ep-nav-btn:hover { opacity: 0.8; }
.ep-end-note {
  text-align: center;
  margin-top: 28px;
  font-size: 14px;
  font-style: italic;
  opacity: 0.6;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.anim { animation: fadeIn 0.4s ease both; }
